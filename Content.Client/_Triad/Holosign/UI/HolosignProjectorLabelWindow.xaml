<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
               xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
               Title="{Loc 'holoprojector-label-header'}">
    <BoxContainer
        Orientation="Vertical"
        HorizontalExpand="True"
        HorizontalAlignment="Left"
        SetSize="200 150"
        MaxSize="200 150"
        MaxWidth="700">
        <Label Name="DescriptionLabel"
               Text="{Loc 'holoprojector-label-description-label'}"
               StyleClasses="LabelKeyText"/>
        <PanelContainer VerticalExpand="False"
                        HorizontalExpand="True"
                        Margin="0 1 0 1">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BorderThickness="1"
                                  BorderColor="#333333"
                                  BackgroundColor="#141414"/>
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical"
                          Margin="1 0 1 0">
                <BoxContainer Orientation="Vertical">
                    <BoxContainer Orientation="Horizontal">
                        <TextEdit Name="DescriptionTextBox"
                                  HorizontalExpand="True"
                                  VerticalExpand="True"
                                  Margin="1"
                                  MinSize="100 75"/>
                    </BoxContainer>
                </BoxContainer>
            </BoxContainer>
        </PanelContainer>
        <BoxContainer VerticalExpand="true" Orientation="Horizontal">
            <CheckBox Name="ExplicitBox"
                      Text="Explicit"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
