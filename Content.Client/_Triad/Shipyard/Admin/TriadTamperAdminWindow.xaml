<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               Title="Tamper Audit"
               MinSize="900 500"
               SetSize="1600 600">
    <PanelContainer StyleClasses="PanelBackgroundBaseDark">
        <BoxContainer Orientation="Vertical">

            <!-- ===================== AUDIT VIEW ===================== -->
            <BoxContainer Name="AuditView" Orientation="Horizontal" VerticalExpand="True" HorizontalExpand="True" Margin="4">
                <PanelContainer StyleClasses="AngleRect">
                    <BoxContainer Orientation="Vertical" MinWidth="230" Margin="6">
                        <Label Text="Filters" StyleClasses="LabelHeading" />
                        <Label Text="Round" />
                        <BoxContainer Orientation="Horizontal">
                            <Button Name="PrevRoundButton" Text="◄" />
                            <Label Name="RoundLabel" Text="Round -" HorizontalExpand="True" Align="Center" />
                            <Button Name="NextRoundButton" Text="►" />
                        </BoxContainer>
                        <Label Text="Round Time" Margin="0 4 0 0" />
                        <BoxContainer Orientation="Horizontal">
                            <LineEdit Name="RoundTimeFromInput" PlaceHolder="HH:MM:SS" HorizontalExpand="True" />
                            <Label Text="–" Margin="4 0" />
                            <LineEdit Name="RoundTimeToInput" PlaceHolder="HH:MM:SS" HorizontalExpand="True" />
                        </BoxContainer>
                        <Label Text="Player" Margin="0 4 0 0" />
                        <OptionButton Name="PlayerDropdown" HorizontalExpand="True" />
                        <Label Text="Ship name" Margin="0 4 0 0" />
                        <LineEdit Name="ShipNameInput" PlaceHolder="name contains" HorizontalExpand="True" />
                        <Button Name="ApplyButton" Text="Apply Filters" HorizontalExpand="True" Margin="0 4 0 0" />
                        <Control MinHeight="10" />
                        <Label Text="Action" StyleClasses="LabelHeading" />
                        <CheckBox Name="ActionSaveSigned" Text="Save (signed)" />
                        <CheckBox Name="ActionVerifiedTrusted" Text="Verified (trusted)" />
                        <CheckBox Name="ActionVerifiedUntrusted" Text="Verified (untrusted)" />
                        <CheckBox Name="ActionUnsigned" Text="Unsigned" />
                        <CheckBox Name="ActionInvalidSignature" Text="Invalid signature" />
                        <CheckBox Name="ActionMigrated" Text="Migrated (permit)" />
                        <CheckBox Name="ActionRejected" Text="Rejected" />
                        <CheckBox Name="ActionPermitGranted" Text="Permit granted" />
                        <CheckBox Name="ActionPermitRevoked" Text="Permit revoked" />
                    </BoxContainer>
                </PanelContainer>

                <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" Margin="4 0 0 0">
                    <Label Name="CountLabel" Margin="0 0 0 2" />
                    <PanelContainer VerticalExpand="True" StyleClasses="AngleRect">
                        <ScrollContainer Name="FeedScroll" VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                            <BoxContainer Name="FeedContainer" Orientation="Vertical" VerticalExpand="True" />
                        </ScrollContainer>
                    </PanelContainer>

                    <PanelContainer StyleClasses="PanelBackgroundBaseLight" Margin="0 4 0 0">
                        <BoxContainer Orientation="Vertical" Margin="6 4">
                            <Label Name="SelectedLabel" Text="Select an entry to grant a permit." />
                            <BoxContainer Orientation="Horizontal" Margin="0 2 0 0">
                                <Button Name="GrantPermitButton" Text="Grant Permit" Disabled="True" />
                                <LineEdit Name="NotesInput" PlaceHolder="notes (permit)" HorizontalExpand="True" Margin="4 0 0 0" />
                            </BoxContainer>
                        </BoxContainer>
                    </PanelContainer>

                    <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
                        <Button Name="PrevPageButton" Text="Prev" />
                        <Label Name="PageLabel" Margin="8 0" />
                        <Button Name="NextPageButton" Text="Next" />
                    </BoxContainer>

                    <!-- Active permits, in-line with the feed so an admin can grant from a rejected-load
                         row and revoke right here without leaving the audit view. -->
                    <Label Text="Active Permits" StyleClasses="LabelHeading" Margin="0 6 0 2" />
                    <PanelContainer StyleClasses="AngleRect">
                        <ScrollContainer Name="AuditPermitsScroll" HScrollEnabled="False" MinHeight="110" MaxHeight="110">
                            <BoxContainer Name="AuditPermitsContainer" Orientation="Vertical" />
                        </ScrollContainer>
                    </PanelContainer>
                </BoxContainer>
            </BoxContainer>

        </BoxContainer>
    </PanelContainer>
</DefaultWindow>
