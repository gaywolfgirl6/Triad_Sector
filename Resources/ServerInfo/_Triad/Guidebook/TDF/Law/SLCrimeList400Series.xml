    </ColorBox>
    <ColorBox>
      <Box HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="2">
        50,000 credits fine OR up to 60 minutes of imprisonment, and possible dismissal.
      </Box>
    </ColorBox>
